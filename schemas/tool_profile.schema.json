{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://solo-founder-harness/schemas/tool_profile.schema.json",
  "title": "ToolProfile",
  "description": "V3 MCP M2 — capability 기반 도구 정책. 계약 문서용. 런타임 검증은 src/tools/profiles.ts의 수동 validator가 담당(신규 런타임 의존성 0). 향후 정식 validator 도입 시 이 스키마를 사용.",
  "type": "object",
  "required": ["profiles"],
  "properties": {
    "profiles": {
      "type": "array",
      "items": { "$ref": "#/definitions/profile" }
    }
  },
  "definitions": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "capabilities", "bindings", "servers",
        "preapprovedTools", "deniedTools", "permissionMode",
        "allowedDomains", "limits", "secretRefs"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "capabilities": { "type": "array", "items": { "type": "string" } },
        "bindings": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/binding" }
        },
        "servers": { "type": "array", "items": { "$ref": "#/definitions/server" } },
        "preapprovedTools": { "type": "array", "items": { "type": "string" } },
        "deniedTools": { "type": "array", "items": { "type": "string" } },
        "permissionMode": { "enum": ["read_only", "dev_write", "approval_write"] },
        "allowedDomains": {
          "oneOf": [{ "type": "null" }, { "type": "array", "items": { "type": "string" } }]
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxCallsPerStep", "maxResultChars", "maxElapsedMsPerCall"],
          "properties": {
            "maxCallsPerStep": { "type": "integer", "minimum": 0 },
            "maxResultChars": { "type": "integer", "minimum": 0 },
            "maxElapsedMsPerCall": { "type": "integer", "minimum": 0 }
          }
        },
        "secretRefs": { "type": "array", "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" } },
        "source": { "enum": ["official", "vendor", "community"] }
      }
    },
    "binding": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "tools"],
          "properties": { "kind": { "const": "builtin" }, "tools": { "type": "array", "items": { "type": "string" } } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "adapter", "operations"],
          "properties": {
            "kind": { "const": "internal_adapter" },
            "adapter": { "type": "string" },
            "operations": { "type": "array", "items": { "type": "string" } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "server", "tools"],
          "properties": {
            "kind": { "const": "mcp" },
            "server": { "type": "string" },
            "tools": { "type": "array", "items": { "type": "string" } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "command"],
          "properties": {
            "kind": { "const": "cli" },
            "command": { "type": "string" },
            "operations": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "server": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "command": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "url": { "type": "string" },
        "transport": { "enum": ["stdio", "http"] }
      }
    }
  }
}
