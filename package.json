{
  "name": "solo-founder-harness",
  "version": "2.6.0",
  "description": "1인 창업자용 AI 에이전트 워크플로우 하네스 — 아이디어 검토부터 Claude Code 작업 지시문까지. 다른 레포에 설치해 프로젝트별로 사용.",
  "type": "module",
  "bin": {
    "harness": "dist/cli.js"
  },
  "files": [
