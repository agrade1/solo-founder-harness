  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agrade1/solo-founder-harness.git"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc && chmod +x dist/cli.js",
    "harness": "tsx src/cli.ts",
    "acceptance": "bash scripts/acceptance.sh",
    "test": "bash scripts/acceptance.sh",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
